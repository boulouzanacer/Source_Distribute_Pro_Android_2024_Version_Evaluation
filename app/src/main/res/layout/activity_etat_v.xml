<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- TOOLBAR -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/myToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/blue"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            tools:titleEnabled="false"
            tools:navigationIcon="@drawable/ic_arrow_back_24" />

        <!-- SESSION INFO -->
        <LinearLayout
            android:id="@+id/tite_session"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:background="@color/emerald"
            android:orientation="vertical">

            <TextView
                android:id="@+id/user"
                android:textSize="18sp"
                android:padding="3dp"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:text="Tous"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:weightSum="2"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/txtv_wilaya"
                    android:textSize="16sp"
                    android:padding="3dp"
                    android:layout_weight="1"
                    android:textAlignment="center"
                    android:textColor="@color/white"
                    android:text="wilaya:"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/txtv_commune"
                    android:textSize="16sp"
                    android:padding="3dp"
                    android:textAlignment="center"
                    android:textColor="@color/white"
                    android:layout_weight="1"
                    android:text="commune:"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- ✅ HERE is your missing block -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/debut"
                    android:textSize="16sp"
                    android:padding="3dp"
                    android:textAlignment="center"
                    android:textColor="@color/white"
                    android:text="de 10/10/2012 10:30"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/fin"
                    android:textSize="16sp"
                    android:padding="3dp"
                    android:textAlignment="center"
                    android:textColor="@color/white"
                    android:text="vers 05/02/2015 10:30"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true" />
            </RelativeLayout>

        </LinearLayout>

        <!-- CONTENT CONTAINER -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- ERROR -->
            <RelativeLayout
                android:id="@+id/relative_error"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/imageError"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="82dp"
                    android:src="@mipmap/error" />

                <TextView
                    android:id="@+id/textError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/imageError"
                    android:text="Probleme fatal, Ressayer"
                    android:textAlignment="center" />

                <ImageView
                    android:id="@+id/retry"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_below="@+id/textError"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/selector_image_retry"
                    android:clickable="true"
                    android:src="@mipmap/ref" />
            </RelativeLayout>

            <!-- EMPTY -->
            <RelativeLayout
                android:id="@+id/lempty_data"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:padding="15dp">

                <TextView
                    android:id="@+id/txtv_etat_centre_status"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text=""
                    android:textSize="22sp" />
            </RelativeLayout>

            <!-- LOADING -->
            <com.victor.loading.book.BookLoading
                android:id="@+id/bookloading"
                android:layout_width="120dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Patientez SVP ..."
                    android:textSize="10sp"
                    android:textAlignment="center" />
            </com.victor.loading.book.BookLoading>

            <!-- RECYCLER -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/white"
                android:visibility="gone"/>

        </FrameLayout>

    </LinearLayout>

    <!-- POPUP OVERLAY (above content) -->
    <LinearLayout
        android:id="@+id/popupContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/blue"
            android:padding="10dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Clients"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:layout_height="wrap_content"/>

            <ImageView
                android:id="@+id/btnClosePopup"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"/>
        </LinearLayout>

        <!-- ✅ FIXED RECYCLER -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerClients"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical"/>
    </LinearLayout>

    <!-- ✅ FAB (TOP LAYER) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabDraggable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:layout_gravity="bottom|end"
        android:src="@drawable/list_client_verser_24"
        android:contentDescription="fab"
        app:backgroundTint="@color/emerald"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>