<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="0dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/entete_produit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/blue"
            android:maxLines="1"
            android:text="@string/produits"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:id="@+id/view_ddd"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="@color/vert"
        app:layout_constraintTop_toBottomOf="@+id/entete_produit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ✅ ListView scrollable (no ScrollView) -->
    <ListView
        android:id="@+id/expandable_listview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:divider="@color/white"
        android:padding="2dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@+id/view_ddd"
        app:layout_constraintBottom_toTopOf="@+id/Pied_produit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/layout_panier_vente" />

    <!-- Footer -->
    <LinearLayout
        android:id="@+id/Pied_produit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/blue"
        android:weightSum="4.75"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/qte_theorique"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/quantit_th_orique"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/lettre_minus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.25"
            android:gravity="center"
            android:text="-"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/qte_physique"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/qte_physique"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/lettre_equal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.25"
            android:gravity="center"
            android:text="="
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/ecart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/ecart"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/lettre_x"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.25"
            android:gravity="center"
            android:text="X"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/puv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/p_u"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="@color/white" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>